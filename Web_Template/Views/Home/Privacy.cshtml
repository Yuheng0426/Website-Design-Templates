@{
    ViewData["Title"] = "Studio Principles";
}

<section class="guide-hero">
    <div class="container">
        <p class="eyebrow" data-i18n="principles.eyebrow">Principles</p>
        <h1 data-i18n="principles.title">How Axyronis Studio builds better digital experiences</h1>
        <p data-i18n="principles.description">Strong websites are shaped by clarity, confidence, and continuous improvement.</p>
    </div>
</section>

<section class="section-block">
    <div class="container guide-layout">
        <article class="guide-card">
            <!-- Principles card: explain what makes the studio process valuable. -->
            <h2 data-i18n="principles.card1.title">Design With Purpose</h2>
            <ul class="guide-list">
                <li><strong data-i18n="principles.card1.point1.label">Clear positioning:</strong> <span data-i18n="principles.card1.point1.text">The audience should know what you offer and why it matters without guessing.</span></li>
                <li><strong data-i18n="principles.card1.point2.label">Useful structure:</strong> <span data-i18n="principles.card1.point2.text">Every section should answer a visitor question or move them closer to action.</span></li>
                <li><strong data-i18n="principles.card1.point3.label">Consistent identity:</strong> <span data-i18n="principles.card1.point3.text">Typography, spacing, imagery, and color should support one recognizable brand feeling.</span></li>
                <li><strong data-i18n="principles.card1.point4.label">Measured decisions:</strong> <span data-i18n="principles.card1.point4.text">Improvements should come from feedback, analytics, and real user behavior.</span></li>
            </ul>
        </article>

        <article class="guide-card">
            <!-- Improvement card: describe practical website enhancement priorities. -->
            <h2 data-i18n="principles.card2.title">Improve What Matters</h2>
            <ol class="guide-list">
                <li data-i18n="principles.card2.point1">Clarify the primary audience before adding new sections.</li>
                <li data-i18n="principles.card2.point2">Make the main call to action easy to find on every important page.</li>
                <li data-i18n="principles.card2.point3">Replace generic claims with proof, examples, and specific outcomes.</li>
                <li data-i18n="principles.card2.point4">Review mobile layouts carefully because many first impressions happen on small screens.</li>
            </ol>
        </article>
    </div>
</section>
